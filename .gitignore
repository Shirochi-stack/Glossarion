# Ignore everything by default
/*

# Allow specific root files
!.gitignore
!README.md
!LICENSE
!requirements.txt
!requirements_Cuda.txt
!requirements_NoCuda.txt
!install_requirements.bat
!build_msix.bat
requirements-dev.txt

# Allow .github, docs, assets folders if present
!.github/
!.github/**
!docs/
!docs/**
!assets/
!assets/**
!tools/
tools/**
!tools/msix/
!tools/msix/**
!extension/
!extension/**

# Only include src, but exclude all subfolders; allow only top-level .py and .spec files
!src/
# Ignore everything under src by default (including all subfolders)
src/**
# Allow only top-level files directly under src (no subfolders)
!src/*.py
!src/*.pyproject
!src/*.spec
!src/*.bat
!src/*.vbs
!src/*.png
!src/*.manifest
# Explicitly include application icon in src
!src/Halgakos.ico

# Allow android subfolder (Kivy/KivyMD Android entry point)
!src/android/
!src/android/**
!src/android/launch_pyside_gui.bat
!src/android/pyside_launcher/
!src/android/pyside_launcher/*.py
!src/android/pyside_launcher/*.spec
!src/android/pyside_launcher/*.md

# Never commit secrets and configs anywhere
**/config.json
*.key
*_key
.glossarion_key

# Never commit logs anywhere
*.log
logs/
**/logs/

# Exclude Python caches and compiled artifacts
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Allow C++ and DLL files
!*.cpp
!*.dll

# Do not commit text files by default (change if needed)
*.txt
# But always include requirements files
!requirements.txt
!requirements_Cuda.txt
!requirements_NoCuda.txt
!requirements-*.txt
howtoruntest.txt

# Exclude all JSON by default (change if needed)
*.json
PATH
PATH
src/test_azure.py
src/test_azure.py
src/test_azure.py

# Explicitly ignore local PowerShell helper
src/wait_and_open.ps1

# Ignore test folders and Warp markdown file
tests/
!tests/
tests/**
!tests/test_sdlxliff_support.py
!tests/test_sdlxliff_json_batch.py
!tests/test_google_free_translate.py
!tests/test_gemini_free_budget.py
!tests/test_glossary_dedup_logging.py
!tests/test_shutdown_utils_cleanup.py
junktests/
warp.md
